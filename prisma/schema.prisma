generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/sales_travel/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model SearchEvent {
  id          String   @id @default(cuid())
  kind        String   // "flight" | "hotel"
  origin      String?
  destination String?
  query       String?
  depart      String?
  return      String?
  marker      String?
  referer     String?
  createdAt   DateTime @default(now())

  @@index([kind, createdAt])
  @@index([origin, destination])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  route     String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
}
